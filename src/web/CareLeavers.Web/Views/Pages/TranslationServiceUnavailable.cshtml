@model CareLeavers.Web.Models.Content.Page
@{
    ViewBag.Title = Model.Title ?? "Sorry, there is a problem with translating this website";
    Layout = "_ErrorLayout";
}

@section Head
{
    <meta name="robots" content="noindex, nofollow"/>
}

@section BeforeGDSContent
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <h1 class="govuk-heading-xl">
                @ViewBag.Title
            </h1>
        </div>
    </div>
}

@if (Model.MainContent is not null && Model.MainContent.Content.Any())
{
    <gds-contentful-rich-text document="@Model.MainContent" dynamic-time="true"/>
}
else
{
    <p class="govuk-body">Try again later.</p>
}